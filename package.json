{
  "name": "telegram-bot",
  "version": "1.0.0",
  "description": "Bot de Telegram para guardar artículos en Supabase",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "backfill-articles": "node src/jobs/backfill-user-articles.js",
    "backfill-metadata": "node src/jobs/backfill-article-metadata.js",
    "update-readme": "node scripts/update-readme.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop que-leo",
    "pm2:restart": "pm2 restart que-leo",
    "pm2:logs": "pm2 logs que-leo",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.50.1",
    "cors": "2.8.5",
    "dotenv": "16.6.0",
    "express": "4.22.2",
    "express-rate-limit": "7.5.0",
    "helmet": "8.0.0",
    "node-telegram-bot-api": "0.67.0",
    "pino": "9.6.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.8",
    "jest": "29.7.0",
    "supertest": "7.1.3"
  }
}
